{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "composer install --optimize-autoloader --no-scripts --no-interaction && php artisan key:generate && php artisan migrate --force"
  },
  "deploy": {
    "startCommand": "php artisan serve --host=0.0.0.0 --port=$PORT",
    "healthcheckPath": "/",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "variables": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "APP_URL": "${{RAILWAY_PUBLIC_DOMAIN}}",
    "LOG_CHANNEL": "stderr",
    "LOG_LEVEL": "error",
    "DB_CONNECTION": "mysql",
    "DB_HOST": "${{MYSQLHOST}}",
    "DB_PORT": "${{MYSQLPORT}}",
    "DB_DATABASE": "${{MYSQLDATABASE}}",
    "DB_USERNAME": "${{MYSQLUSER}}",
    "DB_PASSWORD": "${{MYSQLPASSWORD}}"
  }
}
